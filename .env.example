# 内网 vLLM 部署的 Qwen3（OpenAI 兼容接口），跟课题四后端连的是同一个模型服务
# 一般形如 http://<内网地址>:8000/v1，具体地址找负责部署vLLM的同事要
LLM_BASE_URL=http://localhost:8000/v1

# vLLM 默认不校验 api_key；如果部署时加了 --api-key 参数，这里填真实值，
# 没加的话随便填个非空字符串就行（openai SDK要求这个字段非空）
LLM_API_KEY=EMPTY

# 部署的模型名，以 vLLM 启动命令里 --served-model-name 为准，不是随便写的
LLM_MODEL=Qwen3-32B

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=8192
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
# vLLM版本/启动参数不支持 response_format={"type":"json_object"} 的话改成 false
LLM_USE_JSON_RESPONSE_FORMAT=true

SERVICE_PORT=8003
LOG_LEVEL=INFO

# Qwen3 是混合推理模型，默认可能开着思考模式（回答前先生成一大段<think>过程），
# 对结构化抽取任务没必要还显著拖慢速度、增加超时概率，默认关掉；
# 如果 vLLM/模型版本不支持 enable_thinking 这个参数导致报错，改成 false
LLM_DISABLE_THINKING=true

# 同一时刻最多有几个请求真正转发给vLLM，超过的排队等待
# （2026-07-14生产事故：并发请求太多+其中有带图片的多模态请求，把vLLM的GPU显存压爆导致引擎崩溃）
LLM_MAX_CONCURRENT_REQUESTS=4
